@page "/debug"

@using System.Diagnostics
@using Microsoft.Extensions.Logging
@using System.Text
@using System.IO
@using BlazorComponents.Services.Logging
@implements IDisposable

<PageTitle>Logs Viewer</PageTitle>

<div class="log-container">
    <h3 style="color: white;">Application Logs</h3>

    <div class="button-group">
        <button class="btn-refresh" @onclick="RefreshLogs">Refresh</button>
        <button class="btn-clear" @onclick="ClearLogs">Clear Logs</button>
        <button class="btn-export" @onclick="ExportLogs">Export Logs</button>
        @if (Debugger.IsAttached)
        {
            <button class="btn-test" @onclick="TestLog">Test Log</button>
        }
    </div>

    <div class="filter-control">
        <label for="logLevelFilter" style="color: white;">Filter by level:</label>
        <select id="logLevelFilter" @bind="selectedLogLevel" @bind:after="FilterLogs">
            <option value="">All</option>
            <option value="Trace">Trace</option>
            <option value="Debug">Debug</option>
            <option value="Information">Information</option>
            <option value="Warning">Warning</option>
            <option value="Error">Error</option>
            <option value="Critical">Critical</option>
        </select>
    </div>

            <div class="table-container" style="max-height: 500px; overflow-y: auto;">
        <table class="log-table">
            <thead>
            <tr>
                <th style="color: #212529; background-color: #e9ecef; position: sticky; top: 0;">Time</th>
                <th style="color: #212529; background-color: #e9ecef; position: sticky; top: 0;">Level</th>
                <th style="color: #212529; background-color: #e9ecef; position: sticky; top: 0;">Category</th>
                <th style="color: #212529; background-color: #e9ecef; position: sticky; top: 0;">Message</th>
                <th style="color: #212529; background-color: #e9ecef; position: sticky; top: 0;">Exception</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var log in filteredLogs.OrderByDescending(l => l.Timestamp))
            {
                <tr class="log-row-@log.Level.ToString().ToLower()">
                    <td style="color: #212529;">@log.Timestamp.ToString("HH:mm:ss.fff")</td>
                    <td>
                        <span class="log-badge-@log.Level.ToString().ToLower()">
                            @log.Level
                        </span>
                    </td>
                    <td style="color: #212529;">@log.Category</td>
                    <td style="color: #212529;">@log.Message</td>
                    <td>
                        @if (log.Exception != null)
                        {
                            <button class="btn-exception"
                                    @onclick="() => ShowException(log.Exception)">
                                Show
                            </button>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    @if (logs.Count == 0)
    {
        <div class="log-alert">
            No logs to display
        </div>
    }
</div>

<!-- Modal for exception -->
@if (selectedException != null)
{
    <div class="custom-modal" tabindex="-1" role="dialog">
        <div class="modal-container">
            <div class="modal-box">
                <div class="modal-header">
                    <h5 class="modal-title" style="color: #212529;">Exception Details</h5>
                    <button type="button" class="modal-close" @onclick="CloseExceptionModal">×</button>
                </div>
                <div class="modal-body" style="color: #212529;">
                    <pre style="color: #212529;">@selectedException.ToString()</pre>
                </div>
                <div class="modal-footer">
                    <button type="button" class="modal-btn" @onclick="CloseExceptionModal">
                        Close
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-overlay"></div>
}

@code {
    [Inject]
    private MemoryLogService LogService { get; set; } = null!;
    [Inject]
    private ILogger<Debug> Logger { get; set; } = null!;

    private List<LogEntry> logs = new();
    private List<LogEntry> filteredLogs = new();
    private string selectedLogLevel = "";
    private Exception? selectedException;
    private Timer? refreshTimer;

    protected override void OnInitialized()
    {
        LogService.LogsChanged += OnLogsChanged;
        RefreshLogs();

        // Setup timer for auto-refresh
        refreshTimer = new Timer(async void (_) =>
        {
            await InvokeAsync(() =>
            {
                RefreshLogs();
                StateHasChanged();
            });
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(2));
    }

    private void OnLogsChanged()
    {
        InvokeAsync(() =>
        {
            RefreshLogs();
            StateHasChanged();
        });
    }

    private void RefreshLogs()
    {
        logs = LogService.GetLogs();
        FilterLogs();
    }

    private void FilterLogs()
    {
        if (string.IsNullOrEmpty(selectedLogLevel))
        {
            filteredLogs = logs;
        }
        else
        {
            if (Enum.TryParse<LogLevel>(selectedLogLevel, out var level))
            {
                filteredLogs = logs.Where(l => l.Level == level).ToList();
            }
        }
    }

    private void ClearLogs()
    {
        LogService.ClearLogs();
        RefreshLogs();
    }

    private void TestLog()
    {
        Logger.LogInformation("Test log message at {Time}", DateTime.Now);
        Logger.LogWarning("Test warning message");
        Logger.LogError("Test error message");
        try
        {
            throw new InvalidOperationException("Test exception");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Test exception log");
        }
        StateHasChanged();
    }

    private void ShowException(Exception exception)
    {
        selectedException = exception;
    }

    private void CloseExceptionModal()
    {
        selectedException = null;
    }

    private void ExportLogs()
    {
        try
        {
            // Create a formatted log text
            var sb = new StringBuilder();

            // Add each log entry in a readable format
            foreach (var log in filteredLogs.OrderBy(l => l.Timestamp))
            {
                sb.AppendLine($"[{log.Timestamp:yyyy-MM-dd HH:mm:ss.fff}] [{log.Level}] [{log.Category}] {log.Message}");

                // Add exception details if available
                if (log.Exception != null)
                {
                    sb.AppendLine($"Exception: {log.Exception}");
                    sb.AppendLine();
                }
            }

            var fileName = $"application_logs_{DateTime.Now:yyyyMMdd_HHmmss}.log";
            var logContent = sb.ToString();

            // In a pure Blazor WebAssembly or Server app, we need to implement a file download
            // through the server side, or we'd need a minimal JS Interop. 
            // Let's add a method to save logs to a specific directory on the server.

            // Save to a file in the logs directory
            var logsDirectory = Path.Combine(AppContext.BaseDirectory, "logs");
            Directory.CreateDirectory(logsDirectory); // Ensure directory exists

            var filePath = Path.Combine(logsDirectory, fileName);
            File.WriteAllText(filePath, logContent);

            Logger.LogInformation("Logs exported to file: {FilePath}", filePath);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error exporting logs to file");
        }
    }

    public void Dispose()
    {
        LogService.LogsChanged -= OnLogsChanged;
        refreshTimer?.Dispose();
    }

}