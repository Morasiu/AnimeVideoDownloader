@page "/debug"
@using Microsoft.Extensions.Logging
@using BlazorComponents.Services
@inject ILogger<Debug> Logger
@implements IDisposable

<h1>Debug Console</h1>

<div class="debug-container">
    <div class="debug-console">
        <div class="console-header">
            <h2>Application Log</h2>
            <div class="console-actions">
                <button class="btn btn-sm btn-outline-danger" @onclick="ClearLogs">Clear Logs</button>
            </div>
        </div>
        <div class="console-output">
            @foreach (var entry in DebugLoggerProvider.LogEntries)
            {
                <div class="@GetLogLevelClass(entry.Level)">@entry.FormattedMessage</div>
            }
        </div>
    </div>
</div>

@code {
    [Inject]
    private DebugLoggerProvider LoggerProvider { get; set; } = null!;

    protected override void OnInitialized()
    {
        // Set the static action to capture logs
        DebugLoggerProvider.LogMessageAction = CaptureLog;

        // Log initialization message if this is the first time
        if (DebugLoggerProvider.LogEntries.Count == 0)
        {
            LogMessage(LogLevel.Information, "Debug console initialized.", "Debug");
        }
    }

    private void CaptureLog(LogLevel logLevel, string category, string message)
    {
        InvokeAsync(() => {
            LogMessage(logLevel, message, category);
            StateHasChanged();
        });
    }

    private void LogMessage(LogLevel logLevel, string message, string? category = null)
    {
        var categoryDisplay = !string.IsNullOrEmpty(category) ? $"[{category}] " : "";
        var formattedMessage = $"{DateTime.Now:T} [{logLevel.ToString().ToUpper()}] {categoryDisplay}{message}";
        DebugLoggerProvider.AddLogEntry(logLevel, category ?? "", message, formattedMessage);
    }

    private string GetLogLevelClass(LogLevel level)
    {
        return level switch
        {
            LogLevel.Information => "text-info",
            LogLevel.Warning => "text-warning",
            LogLevel.Error => "text-danger",
            LogLevel.Critical => "text-danger fw-bold",
            LogLevel.Debug => "text-secondary",
            LogLevel.Trace => "text-muted",
            _ => "text-light"
        };
    }

    private void ClearLogs()
    {
        DebugLoggerProvider.LogEntries.Clear();
        LogMessage(LogLevel.Information, "Logs cleared", "Debug");
    }

    public void Dispose()
    {
        // Only dispose the provider when the application is shutting down, not when navigating
        // We're keeping this empty to prevent provider disposal during navigation
    }
}