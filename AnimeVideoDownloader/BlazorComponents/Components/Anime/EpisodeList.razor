@using BlazorComponents.Services.AppData
@using BlazorComponents.Services.YoutubeDLService
@using Microsoft.Extensions.Logging
@inject IAnimeService AnimeService

<div class="episodes-section">
    <h3>Episodes</h3>
    <div class="episode-list">
        @foreach (var episode in Anime.Episodes)
        {
            <div class="episode-item @AnimeService.GetEpisodeStatusClass(episode.Status)">
                <div class="episode-number">@episode.Number</div>
                <div class="episode-title">@episode.Title</div>
                <div class="episode-status">@AnimeService.GetStatusText(episode.Status)</div>
                <div class="episode-actions">
                    @if (episode.Status == EpisodeStatus.Error)
                    {
                        <button class="retry-btn" @onclick="() => RetryDownload(episode)"><i class="fas fa-redo"></i>
                            Retry
                        </button>
                    }
                    @if (episode.Status == EpisodeStatus.Downloaded)
                    {
                        <button class="play-btn" @onclick="() => PlayEpisode(episode)"><i class="fas fa-play"></i> Play
                        </button>
                    }
                    else if (episode.Status != EpisodeStatus.InProgress)
                    {
                        <button class="download-btn" @onclick="() => DownloadEpisode(episode)"><i
                                class="fas fa-download"></i> Download
                        </button>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public AnimeModel Anime { get; set; } = null!;

    [Parameter]
    public EventCallback<EpisodeModel> OnEpisodeAction { get; set; }

    [Inject]
    public DownloaderService DownloaderService { get; set; }

    [Inject]
    public ILogger<EpisodeList> Logger { get; set; }

    private CancellationTokenSource cts = new CancellationTokenSource();

    private async Task RetryDownload(EpisodeModel episode)
    {
        // Implement retry functionality
        await OnEpisodeAction.InvokeAsync(episode);
    }

    private async Task PlayEpisode(EpisodeModel episode)
    {
        // Implement play functionality
        await OnEpisodeAction.InvokeAsync(episode);
    }

    private async Task DownloadEpisode(EpisodeModel episode)
    {
        var downloadProgress = new Progress<AnimeDownloadDownloadProgress>(p => 
            Logger.LogInformation("Download progress - Status: {Status}, Progress: {Progress:P}, Speed: {Speed}, ETA: {Eta}, TotalBytes: {TotalBytes}, Error: {Error}", 
                p.Status, p.Progress, p.DownloadSpeed, p.ETA, p.TotalBytes, p.Error ?? "None")
            );
         await DownloaderService.DownloadAsync("https://www.youtube.com/watch?v=XfELJU1mRMg", AppDataPath.AnimeDownloaderPath, downloadProgress, ct: cts.Token);
    }

}
