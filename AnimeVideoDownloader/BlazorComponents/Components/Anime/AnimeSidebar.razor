@using BlazorComponents.Services.DirectorySelection
@inject IAnimeService AnimeService
@inject IDirectorySelectionService DirectorySelectionService

<aside class="sidebar">
    <div class="sidebar-header">
        <h3><i class="fas fa-film me-2"></i> Anime Library</h3>
        <button class="add-open-btn" @onclick="OpenAddModal"><i class="fas fa-plus"></i> Add</button>
    </div>

    <div class="sidebar-filter">
        <div class="search-box">
            <span class="search-icon"><i class="fas fa-filter"></i></span>
            <input type="text" placeholder="Filter titles" @bind="SearchQuery" @oninput="OnSearchInput" />
        </div>
    </div>

    <div class="anime-list">
        @foreach (var anime in FilteredAnimeList)
        {
            <button class="@GetAnimeItemClass(anime)" @onclick="() => SelectAnimeItem(anime)">
                <div class="anime-title-container">
                    @if (AnimeService.HasDownloadingEpisodes(anime))
                    {
                        <i class="fas fa-circle-notch fa-spin text-blue status-icon-left"></i>
                    }
                    else if (AnimeService.HasErrorEpisodes(anime))
                    {
                        <i class="fas fa-exclamation-circle text-red status-icon-left"></i>
                    }
                    else
                    {
                        <i class="fas fa-check text-green status-icon-left"></i>
                    }
                    <span class="anime-title">@anime.Title</span>
                </div>
                <span class="anime-episode-count">@anime.Episodes.Count</span>
            </button>
        }
    </div>

    <Modal IsOpen="@isAddModalOpen" Title="Add Anime by URL" OnClose="CloseAddModal">
        <ChildContent>
            <div class="form-group">
                <label for="anime-url">URL</label>
                <input id="anime-url" type="url" placeholder="https://..." @bind="AddUrl" />
            </div>

            <div class="form-group">
                <label for="anime-directory">Directory *</label>
                <div class="directory-selection">
                    <input id="anime-directory" type="text" placeholder="C:\Downloads\Anime" @bind="AddDirectory" readonly />
                    <button type="button" class="browse-btn" @onclick="SelectDirectory">
                        <i class="fas fa-folder-open"></i> Browse
                    </button>
                </div>
            </div>
            
            <div class="form-group">
                <label for="anime-title">Title (optional)</label>
                <input id="anime-title" type="text" placeholder="Custom title" @bind="AddTitle" />
            </div>
            @if (!string.IsNullOrEmpty(AddError))
            {
                <div class="add-error">@AddError</div>
            }
        </ChildContent>
        <Footer>
            <button class="secondary-btn" @onclick="CloseAddModal">Cancel</button>
            <button class="primary-btn" @onclick="AddAnimeFromModalAsync"><i class="fas fa-plus"></i> Add</button>
        </Footer>
    </Modal>
</aside>

@code {
    [Parameter]
    public AnimeModel? SelectedAnime { get; set; }

    [Parameter]
    public EventCallback<AnimeModel> OnAnimeSelected { get; set; }

    private string SearchQuery { get; set; } = string.Empty;
    private List<AnimeModel> AnimeList { get; set; } = new();

    // Modal state
    private bool isAddModalOpen;
    private string AddUrl { get; set; } = string.Empty;
    private string AddTitle { get; set; } = string.Empty;
    private string AddDirectory { get; set; } = string.Empty;
    private string? AddError { get; set; }

    private List<AnimeModel> FilteredAnimeList => 
        string.IsNullOrEmpty(SearchQuery) 
            ? AnimeList 
            : AnimeList.Where(a => a.Title.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)).ToList();

    protected override void OnInitialized()
    {
        AnimeList = AnimeService.GetAnimeList();
    }

    private void OpenAddModal()
    {
        AddUrl = string.Empty;
        AddTitle = string.Empty;
        AddDirectory = string.Empty;
        AddError = null;
        isAddModalOpen = true;
    }

    private void CloseAddModal()
    {
        isAddModalOpen = false;
    }

    private async Task AddAnimeFromModalAsync()
    {
        AddError = null;
        var url = AddUrl.Trim();
        var directory = AddDirectory.Trim();
        
        if (string.IsNullOrWhiteSpace(url))
        {
            AddError = "Please provide a valid URL.";
            return;
        }
        
        if (string.IsNullOrWhiteSpace(directory))
        {
            AddError = "Please provide a valid directory.";
            return;
        }
        
        try
        {
            var newAnime = await AnimeService.AddAnimeFromUrlAsync(url, directory);
            if (!string.IsNullOrWhiteSpace(AddTitle))
            {
                newAnime.Title = AddTitle.Trim();
            }
            // Refresh list reference and UI
            AnimeList = AnimeService.GetAnimeList();
            SearchQuery = string.Empty;
            isAddModalOpen = false;
            await OnAnimeSelected.InvokeAsync(newAnime);
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            AddError = ex.Message;
        }
    }

    private async Task SelectAnimeItem(AnimeModel anime)
    {
        await OnAnimeSelected.InvokeAsync(anime);
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        SearchQuery = e.Value?.ToString() ?? string.Empty;
    }

    private string GetAnimeItemClass(AnimeModel anime)
    {
        var isActive = SelectedAnime?.Id == anime.Id;
        return isActive ? "anime-item active" : "anime-item";
    }

    private void SelectDirectory()
    {
        try
        {
            var selectedDirectory = DirectorySelectionService.SelectDirectory(AddDirectory);
            if (!string.IsNullOrEmpty(selectedDirectory))
            {
                AddDirectory = selectedDirectory;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            AddError = $"Error selecting directory: {ex.Message}";
        }
    }
}
