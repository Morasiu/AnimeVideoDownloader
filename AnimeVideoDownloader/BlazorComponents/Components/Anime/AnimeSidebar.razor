@inject IAnimeService AnimeService

<aside class="sidebar">
    <div class="sidebar-header">
        <h3><i class="fas fa-film me-2"></i> Anime Library</h3>
    </div>

    <div class="sidebar-filter">
        <div class="search-box">
            <span class="search-icon"><i class="fas fa-filter"></i></span>
            <input type="text" placeholder="Filter titles" @bind="SearchQuery" @oninput="OnSearchInput" />
        </div>
    </div>

    <div class="anime-list">
        @foreach (var anime in FilteredAnimeList)
        {
            <button class="anime-item @(SelectedAnime?.Id == anime.Id ? "active" : "")" @onclick="() => SelectAnimeItem(anime)">
                <div class="anime-title-container">
                    @if (AnimeService.HasDownloadingEpisodes(anime))
                    {
                        <i class="fas fa-circle-notch fa-spin text-blue status-icon-left"></i>
                    }
                    else if (AnimeService.HasErrorEpisodes(anime))
                    {
                        <i class="fas fa-exclamation-circle text-red status-icon-left"></i>
                    }
                    else
                    {
                        <i class="fas fa-check text-green status-icon-left"></i>
                    }
                    <span class="anime-title">@anime.Title</span>
                </div>
                <span class="anime-episode-count">@anime.Episodes.Count</span>
            </button>
        }
    </div>
</aside>

@code {
    [Parameter]
    public AnimeModel? SelectedAnime { get; set; }

    [Parameter]
    public EventCallback<AnimeModel> OnAnimeSelected { get; set; }

    private string SearchQuery { get; set; } = "";
    private List<AnimeModel> AnimeList { get; set; } = new();

    private List<AnimeModel> FilteredAnimeList => 
        string.IsNullOrEmpty(SearchQuery) 
            ? AnimeList 
            : AnimeList.Where(a => a.Title.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)).ToList();

    protected override void OnInitialized()
    {
        AnimeList = AnimeService.GetAnimeList();
    }

    private async Task SelectAnimeItem(AnimeModel anime)
    {
        await OnAnimeSelected.InvokeAsync(anime);
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        SearchQuery = e.Value?.ToString() ?? "";
    }
}
