@using System.Linq
@using BlazorComponents.Services.Logging


<nav class="top-nav">
    <div class="left-section">
        <div class="logo">
            <div class="logo-icon"><i class="fas fa-tv"></i></div>
            <span class="logo-text">AniLoad</span>
        </div>

        <div class="nav-menu">
            <NavLink class="nav-item" href="" Match="NavLinkMatch.All" ActiveClass="active">
                <span class="nav-icon"><i class="fas fa-home"></i></span>
                <span class="nav-text">Home</span>
            </NavLink>
        </div>
    </div>

    <div class="right-section">
        
        <StatusIndicator />

        <NavLink class="nav-item" href="settings" ActiveClass="active">
            <span class="nav-icon"><i class="fas fa-cog"></i></span>
            <span class="nav-text">Settings</span>
        </NavLink>

        <NavLink class="nav-item" href="debug" ActiveClass="active">
            <span class="nav-icon"><i class="fas fa-bug"></i></span>
            <span class="nav-text">Debug</span>
            @if (HasExceptions)
            {
                <span class="error-badge"><i class="fas fa-exclamation-circle"></i></span>
            }
        </NavLink>
    </div>
</nav>

@code {
    [Inject] private MemoryLogService LogService { get; set; } = default!;

    private bool HasExceptions => LogService.GetLogs().Any(log => log.Exception != null);

    protected override void OnInitialized()
    {
        LogService.LogsChanged += StateHasChanged;
    }

    public void Dispose()
    {
        LogService.LogsChanged -= StateHasChanged;
    }
}

@implements IDisposable
